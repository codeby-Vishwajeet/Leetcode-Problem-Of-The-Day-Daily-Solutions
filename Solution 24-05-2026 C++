#include <vector>
#include <algorithm>

using namespace std;

class Solution {
private:
    int dfs(int i, const vector<int>& arr, int d, vector<int>& dp) {
        // Return precomputed result if already visited
        if (dp[i] != 0) {
            return dp[i];
        }
        
        int n = arr.size();
        int max_jumps = 1; // You always visit at least the starting index itself
        
        // Check valid jumps to the Right
        for (int j = i + 1; j <= min(i + d, n - 1); ++j) {
            // Blocked by a building that is taller or equal
            if (arr[j] >= arr[i]) {
                break; 
            }
            max_jumps = max(max_jumps, 1 + dfs(j, arr, d, dp));
        }
        
        // Check valid jumps to the Left
        for (int j = i - 1; j >= max(i - d, 0); --j) {
            // Blocked by a building that is taller or equal
            if (arr[j] >= arr[i]) {
                break; 
            }
            max_jumps = max(max_jumps, 1 + dfs(j, arr, d, dp));
        }
        
        // Memoize and return
        return dp[i] = max_jumps;
    }

public:
    int maxJumps(vector<int>& arr, int d) {
        int n = arr.size();
        vector<int> dp(n, 0);
        int ans = 0;
        
        // Try starting from every possible index and find the global maximum
        for (int i = 0; i < n; ++i) {
            ans = max(ans, dfs(i, arr, d, dp));
        }
        
        return ans;
    }
};
